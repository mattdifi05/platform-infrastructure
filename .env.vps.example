# Copy this file over/into .env on the VPS, then replace every example domain.
# TLS/certificates are expected at the VPS/edge/CDN layer, not inside Docker.

TRAEFIK_HTTP_BIND=80
WAF_HTTP_BIND=0.0.0.0:80
WAF_BACKEND=http://traefik:80
WAF_NGINX_ALWAYS_TLS_REDIRECT=off
WAF_X_FORWARDED_PROTO=https
WAF_BLOCKING_PARANOIA=2
WAF_DETECTION_PARANOIA=2
WAF_ANOMALY_INBOUND=5
WAF_ANOMALY_OUTBOUND=4
TRAEFIK_ACME_EMAIL=ops@example.com

BACKEND_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-backend:replace-me
WEB_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-web:replace-me
WORKER_NOTIFICATIONS_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-worker-notifications:replace-me
WORKER_JOBS_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-worker-jobs:replace-me

PLATFORM_NAME=Platform Infrastructure
PROJECT_NAME=platform
DOMAIN=example.com
LOCAL_DOMAIN=sslip.io
PROVIDER_PROFILE=generic-vps
ADMIN_HOST=admin.example.com
CONTROL_CENTER_HOST=admin.example.com
DOCS_HOST=docs.example.com
DEFAULT_PUBLIC_APP_HOST=app.example.com
DEFAULT_API_HOST=
APP_HOST=app.example.com
UI_HOST=
ACCOUNT_HOST=
API_HOST=
AUTH_HOST=
STORAGE_HOST=
PROJECTS_HOST=
PROJECTS_WILDCARD_HOST_REGEXP=
PROJECT_HOST_SUFFIX=.example.com
CONTROL_CENTER_ENV=production
CONTROL_CENTER_AUTH_REQUIRED=true
CONTROL_CENTER_ADMIN_PASSWORD_SHA256=replace_with_sha256_of_admin_password
NODE_PROJECT_HOSTS=
NODE_PROJECT_UPSTREAMS=
NODE_PROJECT_COMMANDS=
NODE_PROJECT_ENV=production

KEYCLOAK_HOSTNAME=keycloak.local
KEYCLOAK_HOSTNAME_STRICT=true

NEXT_PUBLIC_API_URL=http://backend:3000
NEXT_PUBLIC_UI_URL=https://admin.example.com
NEXT_PUBLIC_ACCOUNT_URL=https://admin.example.com
API_PUBLIC_URL=http://backend:3000
ACCOUNT_PUBLIC_URL=https://admin.example.com
UI_PUBLIC_URL=https://admin.example.com
CONTROL_CENTER_PUBLIC_URL=https://admin.example.com
DOCS_PUBLIC_URL=https://docs.example.com
NEXTAUTH_URL=https://admin.example.com
KEYCLOAK_ISSUER=http://keycloak:8080/realms/platform
WEBAUTHN_RP_ID=admin.example.com
WEBAUTHN_ORIGINS=https://admin.example.com
CORS_ORIGINS=https://admin.example.com
GOOGLE_OAUTH_REDIRECT_URI=http://backend:3000/auth/google/callback

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
API_DOCS_ENABLED=false

MAILER_PROVIDER=smtp
MAILER_FROM=no-reply@example.com
MAILER_REPLY_TO=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com
SMTP_PASSWORD_FILE=/run/secrets/smtp_password
ALERT_EMAIL_TO=ops@example.com
PROJECTS_GATEWAY_EMAIL=ops@example.com

BOT_PROTECTION_PROVIDER=disabled
BOT_PROTECTION_REQUIRED=
BOT_PROTECTION_MIN_SCORE=0.5
BOT_PROTECTION_EXPECTED_HOSTNAMES=account.example.com,admin.example.com

MARIADB_ROOT_PASSWORD_SECRET_FILE=./secrets/mariadb_root_password.txt
