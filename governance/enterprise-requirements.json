{
  "version": 1,
  "scope": "platform-infrastructure",
  "requirements": [
    {
      "id": "vps-hardening-firewall-fail2ban",
      "title": "VPS hardening OS, firewall and fail2ban",
      "state": "gate-ready",
      "evidence": [
        { "type": "file", "path": ".github/workflows/enterprise-vps-evidence.yml" },
        { "type": "file", "path": "scripts/vps-hardening-ubuntu.sh" },
        { "type": "pattern", "path": "scripts/vps-hardening-ubuntu.sh", "pattern": "ufw[\\s\\S]*fail2ban[\\s\\S]*auditd[\\s\\S]*apparmor" },
        { "type": "pattern", "path": "scripts/vps-host-readiness.sh", "pattern": "ufw-active[\\s\\S]*fail2ban-active[\\s\\S]*ssh-hardening" },
        { "type": "workflow", "pattern": "Run VPS evidence on VPS[\\s\\S]*vps-hardening-ubuntu\\.sh[\\s\\S]*vps-host-readiness\\.sh" }
      ],
      "liveProof": "Run vps-hardening-ubuntu.sh --apply and vps-host-readiness.sh --enforce on the VPS Ubuntu LTS VPS.",
      "liveProofChecks": ["vps-hardening-applied", "vps-host-readiness"]
    },
    {
      "id": "real-dns",
      "title": "Real DNS and domain preflight",
      "state": "gate-ready",
      "evidence": [
        { "type": "file", "path": "scripts/production-preflight.sh" },
        { "type": "command", "name": "production-preflight" },
        { "type": "pattern", "path": "scripts/infra-ops.mjs", "pattern": "async function productionPreflight[\\s\\S]*(dns|resolve|host)" }
      ],
      "liveProof": "Run production-preflight with final production domains after Cloudflare DNS is configured.",
      "liveProofChecks": ["pre-go-live-evidence-complete"]
    },
