{
  "version": 1,
  "provider": "cloudflare",
  "external": true,
  "source": "provider-api",
  "verifiedAt": "replace-with-current-utc-timestamp",
  "maxAgeHours": 24,
  "monitors": [
    {
      "targetName": "portal-public-home",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "${CONTROL_CENTER_PUBLIC_URL:-https://portal.platform.example.com}/",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 200,
      "lastLatencyMs": 350,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    },
    {
      "targetName": "docs-public-home",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "${DOCS_PUBLIC_URL:-https://docs.platform.example.com}/",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 200,
      "lastLatencyMs": 350,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    }
  ]
}
