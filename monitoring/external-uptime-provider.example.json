{
  "version": 1,
  "provider": "cloudflare",
  "external": true,
  "source": "provider-api",
  "verifiedAt": "replace-with-current-utc-timestamp",
  "maxAgeHours": 24,
  "monitors": [
    {
      "targetName": "web-public-home",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "${UI_PUBLIC_URL:-https://stexor.example.com}/",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 200,
      "lastLatencyMs": 350,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    },
    {
      "targetName": "api-public-health",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "${API_PUBLIC_URL:-https://api.stexor.example.com}/health",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 200,
      "lastLatencyMs": 180,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    },
    {
      "targetName": "account-public-home",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "${ACCOUNT_PUBLIC_URL:-https://account.stexor.example.com}/",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 200,
      "lastLatencyMs": 350,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    },
    {
      "targetName": "keycloak-issuer-discovery",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "${KEYCLOAK_ISSUER:-https://auth.stexor.example.com/realms/stexor}/.well-known/openid-configuration",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 200,
      "lastLatencyMs": 350,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    },
    {
      "targetName": "blocked-phpmyadmin-public",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "https://phpmyadmin.${PUBLIC_ROOT_DOMAIN:-stexor.example.com}/",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 403,
      "lastLatencyMs": 250,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    },
    {
      "targetName": "blocked-prometheus-public",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "https://prometheus.${PUBLIC_ROOT_DOMAIN:-stexor.example.com}/",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 403,
      "lastLatencyMs": 250,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    },
    {
      "targetName": "blocked-alertmanager-public",
      "monitorId": "replace-with-provider-monitor-id",
      "url": "https://alertmanager.${PUBLIC_ROOT_DOMAIN:-stexor.example.com}/",
      "intervalSeconds": 60,
      "regions": ["eu-west", "us-east"],
      "enabled": true,
      "lastStatus": "up",
      "lastStatusCode": 403,
      "lastLatencyMs": 250,
      "lastCheckedAt": "replace-with-current-utc-timestamp"
    }
  ]
}
