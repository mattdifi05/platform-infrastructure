# Copy to .env.staging on the staging VPS. Staging must use real DNS names,
# separate secrets and separate volumes from production.

COMPOSE_PROJECT_NAME=platform_infra_staging
TRAEFIK_ACME_EMAIL=ops@example.com

BACKEND_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-backend:replace-me
WEB_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-web:replace-me
WORKER_NOTIFICATIONS_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-worker-notifications:replace-me
WORKER_JOBS_IMAGE=ghcr.io/mattdifi05/platform-infrastructure-worker-jobs:replace-me

PLATFORM_NAME=Platform Infrastructure
PROJECT_NAME=platform-staging
DOMAIN=staging.example.com
LOCAL_DOMAIN=sslip.io
PROVIDER_PROFILE=generic-vps
ADMIN_HOST=portal-staging.example.com
CONTROL_CENTER_HOST=portal-staging.example.com
DOCS_HOST=docs-staging.example.com
DEFAULT_PUBLIC_APP_HOST=
DEFAULT_API_HOST=
UI_HOST=
ACCOUNT_HOST=
API_HOST=
AUTH_HOST=
STORAGE_HOST=
PROJECTS_HOST=
PROJECTS_WILDCARD_HOST_REGEXP=
PROJECT_HOST_SUFFIX=.staging.example.com
CONTROL_CENTER_ENV=staging
CONTROL_CENTER_AUTH_REQUIRED=true
CONTROL_CENTER_ADMIN_PASSWORD_SHA256=replace_with_sha256_of_admin_password
NODE_PROJECT_HOSTS=
NODE_PROJECT_UPSTREAMS=
NODE_PROJECT_COMMANDS=
NODE_PROJECT_ENV=production

KEYCLOAK_HOSTNAME=keycloak.local
KEYCLOAK_HOSTNAME_STRICT=true

NEXT_PUBLIC_API_URL=http://backend:3000
NEXT_PUBLIC_UI_URL=https://portal-staging.example.com
NEXT_PUBLIC_ACCOUNT_URL=https://portal-staging.example.com
API_PUBLIC_URL=http://backend:3000
ACCOUNT_PUBLIC_URL=https://portal-staging.example.com
UI_PUBLIC_URL=https://portal-staging.example.com
CONTROL_CENTER_PUBLIC_URL=https://portal-staging.example.com
DOCS_PUBLIC_URL=https://docs-staging.example.com
NEXTAUTH_URL=https://portal-staging.example.com
KEYCLOAK_ISSUER=http://keycloak:8080/realms/platform
WEBAUTHN_RP_ID=portal-staging.example.com
WEBAUTHN_ORIGINS=https://portal-staging.example.com
CORS_ORIGINS=https://portal-staging.example.com
GOOGLE_OAUTH_REDIRECT_URI=http://backend:3000/auth/google/callback

MARIADB_DATA_VOLUME=enterprise_mariadb_data_staging
POSTGRES_DATA_VOLUME=enterprise_postgres_data_staging
REDIS_DATA_VOLUME=enterprise_redis_data_staging
KEYCLOAK_DATA_VOLUME=enterprise_keycloak_data_staging
NATS_DATA_VOLUME=enterprise_nats_data_staging
MINIO_DATA_VOLUME=enterprise_minio_data_staging
GRAFANA_DATA_VOLUME=enterprise_grafana_data_staging
PROMETHEUS_DATA_VOLUME=enterprise_prometheus_data_staging
LOKI_DATA_VOLUME=enterprise_loki_data_staging

MAILER_PROVIDER=smtp
MAILER_FROM=no-reply-staging@example.com
MAILER_REPLY_TO=no-reply-staging@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply-staging@example.com
SMTP_PASSWORD_FILE=/run/secrets/smtp_password
ALERT_EMAIL_TO=ops-staging@example.com
PROJECTS_GATEWAY_EMAIL=ops-staging@example.com

BOT_PROTECTION_PROVIDER=disabled
BOT_PROTECTION_REQUIRED=
BOT_PROTECTION_EXPECTED_HOSTNAMES=account-staging.example.com,portal-staging.example.com

ALERT_FORWARD_WEBHOOK_URL=
RESTIC_REPOSITORY=s3:s3.amazonaws.com/your-restic-bucket/platform-staging
RESTIC_PASSWORD_FILE=./secrets/restic_password.txt
